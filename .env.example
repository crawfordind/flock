# Flock — local development

# Optional: Turso / libSQL cloud sync
# Without these, the app runs fully offline (IndexedDB / Dexie only).
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Optional: SMTP for email session summaries
# Without these, POST /api/email returns a successful stub response.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Flock <flock@example.com>"
